---
import type { FeatureItem } from '../types/drupal';

interface Props {
  field_features_title?: string;
  features?: FeatureItem[];
}

const {
  field_features_title = "The ChefPaws Standard",
  features = []
} = Astro.props;
---

<section class="features-section">
  <div class="container">
    <header class="section-header">
      <h2 class="title">{field_features_title}</h2>
      <p class="subtitle">Precisely formulated. Lightly cooked. Delivered fresh.</p>
    </header>

    <div class="features-grid">
      {features.map((item) => (
        <div class="feature-card">
          <div class="card-content">
            <h3 class="card-title">{item.field_headline}</h3>
            <p class="card-text">{item.field_description}</p>
          </div>
          <div class="card-base-line"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: #ffffff;
    padding: clamp(5rem, 10vw, 9rem) 1.5rem;
    text-align: center;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* --- Header --- */
  .section-header {
    margin-bottom: clamp(4rem, 8vw, 6rem);
  }

  .title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #111;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #888;
    font-weight: 400;
  }

  /* --- Grid --- */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* --- Card --- */
  .feature-card {
    position: relative;
    background: #fcfcfc;
    padding: 4rem 2rem;
    border-radius: 20px;
    border: 1px solid #f0f0f0;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 320px;
  }

  .card-title {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111;
    margin-bottom: 1.25rem;
  }

  .card-text {
    font-size: 1rem;
    line-height: 1.6;
    color: #666;
    margin: 0 auto;
    max-width: 260px;
  }

  /* A single, static accent detail */
  .card-base-line {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: #ff6b6b;
    transition: width 0.4s ease;
  }

  /* --- Interactions --- */
  .feature-card:hover {
    background: #ffffff;
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
    border-color: #eee;
  }

  .feature-card:hover .card-base-line {
    width: 40px; /* Only detail that moves, very subtly */
  }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
    .feature-card { min-height: auto; padding: 3rem 1.5rem; }
  }
</style>