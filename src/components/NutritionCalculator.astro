---
import { ClientRouter } from 'astro:transitions';
---
<head>
  <ClientRouter />
</head>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
  
  :root {
    --brand-dark: #1a1a1a;
    --brand-accent: #ff6b6b;
    --brand-soft: #f4f4f2;
    --brand-surface: #ffffff;
    --text-muted: #666;
    --shadow-soft: 0 20px 40px rgba(0,0,0,0.05);
    --border-light: #eee;
  }

  nutrition-calculator { 
    font-family: 'Plus Jakarta Sans', sans-serif; 
    display: block; 
    background-color: var(--brand-soft); 
    padding: clamp(1rem, 5vw, 4rem) 1rem; 
    min-height: 100vh; 
  }

  .calculator-frame { 
    background: var(--brand-surface); 
    max-width: 1100px; 
    margin: 0 auto; 
    border-radius: clamp(24px, 5vw, 48px); 
    box-shadow: var(--shadow-soft); 
    overflow: hidden; 
  }
  
  .view { padding: clamp(2rem, 8vw, 5rem); display: none; }
  .view.active { display: block; animation: smoothReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  
  @keyframes smoothReveal { 
    from { opacity: 0; transform: translateY(30px); } 
    to { opacity: 1; transform: translateY(0); } 
  }

  .title-display { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 8vw, 7rem); line-height: 0.9; margin-bottom: 2rem; text-transform: uppercase; letter-spacing: -0.02em; }
  .eyebrow-accent { font-weight: 800; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.25em; color: var(--brand-accent); margin-bottom: 1rem; display: block; }
  
  .metric-hero-modern { background: var(--brand-dark); color: white; padding: clamp(2rem, 5vw, 5rem) 1.5rem; border-radius: clamp(20px, 4vw, 40px); margin-bottom: 3rem; text-align: center; }
  .hero-value-polished { font-family: 'Bebas Neue', sans-serif; font-size: clamp(4rem, 15vw, 12rem); line-height: 0.8; display: flex; justify-content: center; align-items: baseline; }
  .hero-value-polished .unit { font-family: 'Plus Jakarta Sans'; font-size: 0.9rem; font-weight: 800; opacity: 0.4; margin-left: 1rem; letter-spacing: 0.1em; }

  .selection-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr)); gap: 1.5rem; width: 100%; }
  
  .glass-card-modern { 
    background: white; 
    border: 1.5px solid var(--border-light); 
    border-radius: clamp(24px, 4vw, 40px); 
    padding: clamp(2rem, 5vw, 4rem) 2rem; 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    text-align: center;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); 
    cursor: pointer;
    width: 100%;
  }

  .glass-card-modern:hover { transform: translateY(-8px); border-color: var(--brand-dark); }
  .glass-card-modern.selected { border-color: var(--brand-accent); background-color: #fff9f9; }

  .plan-count { font-family: 'Bebas Neue', sans-serif; font-size: clamp(4rem, 10vw, 7rem); line-height: 1; color: var(--brand-dark); margin-bottom: 0.5rem; }
  .plan-count span { font-size: 1rem; color: var(--brand-accent); vertical-align: super; text-transform: uppercase; font-weight: 800; }
  .card-label { font-weight: 800; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
  .card-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 2rem; flex-grow: 1; }

  .pill-action-trigger {
    display: flex; align-items: center; justify-content: center;
    background-color: var(--brand-dark); color: #ffffff;
    min-height: 60px; width: 100%; max-width: 320px;
    margin: 0 auto; border-radius: 100px;
    font-weight: 800; font-size: 0.8rem; text-transform: uppercase;
    letter-spacing: 0.1em; cursor: pointer; transition: 0.3s; border: none;
  }
  
  .pill-action-trigger:hover { background-color: var(--brand-accent); transform: translateY(-2px); }
  .pill-action-trigger.disabled { opacity: 0.2; pointer-events: none; }

  .input-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr)); gap: 1.5rem; margin-bottom: 3rem; }
  .field { display: flex; flex-direction: column; background: #f9f9f7; padding: 1.25rem 1.5rem; border-radius: 20px; text-align: left; }
  .field label { font-weight: 800; font-size: 0.65rem; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem; }
  input, textarea { background: transparent; border: none; outline: none; font-family: inherit; font-size: 1.1rem; font-weight: 700; color: var(--brand-dark); width: 100%; }

  .btn-minimal { margin-top: 3rem; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; cursor: pointer; opacity: 0.4; transition: 0.3s; border: none; background: none; width: 100%; }
  .btn-minimal:hover { opacity: 1; color: var(--brand-accent); }
  
  .hidden { display: none !important; }
</style>

<nutrition-calculator data-api-url={import.meta.env.PUBLIC_API_URL || 'http://localhost:8080'}>
  <div class="calculator-frame">
    <div id="phase-1" class="view active">
      <span class="eyebrow-accent">Phase 01: Biological Input</span>
      <h2 class="title-display">Analyze Your Dog</h2>
      <div class="input-grid">
        <div class="field"><label>Dog's Name</label><input type="text" id="dogName" placeholder="e.g. Tony" required /></div>
        <div class="field"><label>Weight (lbs)</label><input type="number" id="weight" placeholder="00" required /></div>
        <div class="field">
          <label>Activity Level (1-5)</label>
          <input type="range" id="activity" min="1" max="5" step="1" value="3" />
        </div>
      </div>
      <div class="pill-action-trigger" id="calc-btn"><span>Analyze Biology</span></div>
    </div>

    <div id="phase-2" class="view">
      <span class="eyebrow-accent">Phase 02: Frequency</span>
      <h2 class="title-display">Select Duration</h2>
      <div class="metric-hero-modern">
        <div class="hero-value-polished"><span id="res-cals"></span><span class="unit">KCAL / DAY</span></div>
      </div>
      <div class="selection-grid">
        <div class="glass-card-modern select-plan-btn" data-plan="5">
          <div class="plan-count">5 <span>Days</span></div>
          <div class="card-label">The Taster</div>
          <p class="card-desc">Perfect for testing the transition.</p>
          <div class="pill-action-trigger"><span>Select</span></div>
        </div>
        <div class="glass-card-modern select-plan-btn" data-plan="10">
          <div class="plan-count">10 <span>Days</span></div>
          <div class="card-label">The Standard</div>
          <p class="card-desc">Most popular for long-term health.</p>
          <div class="pill-action-trigger"><span>Select</span></div>
        </div>
        <div class="glass-card-modern select-plan-btn" data-plan="20">
          <div class="plan-count">20 <span>Days</span></div>
          <div class="card-label">The Pro</div>
          <p class="card-desc">Ideal for high-performance homes.</p>
          <div class="pill-action-trigger"><span>Select</span></div>
        </div>
      </div>
      <button class="btn-minimal" id="reset-to-phase-1">Reset Analysis</button>
    </div>

    <div id="phase-3" class="view">
        <span class="eyebrow-accent">Phase 03: Formulations</span>
        <h2 class="title-display">Craft the Box</h2>
        <div id="recipe-list" class="selection-grid"></div>
        <div style="text-align: center; margin-top: 4rem;">
            <div class="pill-action-trigger disabled" id="confirm-menu-btn"><span>Confirm Selection</span></div>
            <button class="btn-minimal" id="back-to-plans">Adjust Duration</button>
        </div>
    </div>

    <div id="phase-4" class="view">
      <div id="lead-form-container">
          <span class="eyebrow-accent">Phase 04: Finalize</span>
          <h2 class="title-display">Secure Your Spot</h2>
          <form id="lead-capture-form">
            <div class="input-grid">
              <div class="field"><label>Full Name</label><input type="text" id="userName" required /></div>
              <div class="field"><label>Email Address</label><input type="email" id="userEmail" required /></div>
              <div class="field"><label>Phone Number</label><input type="tel" id="userPhone" required /></div>
              <div class="field"><label>Zip Code</label><input type="text" id="userZip" required /></div>
              <div class="field" style="grid-column: 1 / -1;"><label>Special Requirements</label><textarea id="userMessage" rows="3"></textarea></div>
            </div>
            <div class="pill-action-trigger" id="submit-lead-btn"><span>Request Roadmap</span></div>
          </form>
      </div>
      <div id="success-message" class="hidden" style="text-align:center;">
          <h2 class="title-display">Blueprint Sent</h2>
          <button class="btn-minimal" onclick="location.reload()">Start New</button>
      </div>
    </div>
  </div>
</nutrition-calculator>

<script>
  class NutritionCalculator extends HTMLElement {
    constructor() {
      super();
      this.apiUrl = this.getAttribute('data-api-url');
      this.selectedRecipes = new Set();
      this.selectedPlan = null;
      this.calcData = null;

      // Selectors
      this.calcBtn = this.querySelector('#calc-btn');
      this.confirmBtn = this.querySelector('#confirm-menu-btn');
      this.leadBtn = this.querySelector('#submit-lead-btn');

      // Bindings
      this.calcBtn.addEventListener('click', () => this.runEngine());
      this.querySelectorAll('.select-plan-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          this.selectedPlan = e.currentTarget.dataset.plan;
          this.transition('phase-2', 'phase-3');
        });
      });
      
      this.confirmBtn.addEventListener('click', () => this.transition('phase-3', 'phase-4'));
      this.querySelector('#back-to-plans').addEventListener('click', () => this.transition('phase-3', 'phase-2'));
      this.querySelector('#reset-to-phase-1').addEventListener('click', () => this.transition('phase-2', 'phase-1'));
      this.leadBtn.addEventListener('click', () => this.submitLead());
    }

    async runEngine() {
      const name = this.querySelector('#dogName').value;
      const weight = this.querySelector('#weight').value;
      if(!name || !weight) return alert("Fill Name and Weight");
      
      const res = await fetch(`${this.apiUrl}/api/calculate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          name, 
          weightKG: parseFloat(weight)/2.20462, 
          activityLevel: parseInt(this.querySelector('#activity').value) 
        })
      });
      this.calcData = await res.json();
      this.querySelector('#res-cals').textContent = Math.round(this.calcData.dailyCalories);
      this.renderRecipes();
      this.transition('phase-1', 'phase-2');
    }

    renderRecipes() {
      const container = this.querySelector('#recipe-list');
      container.innerHTML = '';
      this.calcData.recipes.forEach(r => {
        const card = document.createElement('div');
        card.className = 'glass-card-modern';
        card.innerHTML = `
          <div class="card-label">${r.recipeName}</div>
          <p class="card-desc">${r.ingredients}</p>
          <div class="plan-count">${r.portionGrams}<span>g</span></div>
        `;
        card.onclick = () => {
          card.classList.toggle('selected');
          this.selectedRecipes.has(r.recipeName) ? this.selectedRecipes.delete(r.recipeName) : this.selectedRecipes.add(r.recipeName);
          this.confirmBtn.classList.toggle('disabled', this.selectedRecipes.size === 0);
        };
        container.appendChild(card);
      });
    }

    transition(from, to) {
      const switchView = () => {
        this.querySelector(`#${from}`).classList.remove('active');
        this.querySelector(`#${to}`).classList.add('active');
        
        // Ensure the card is focused at the top after change
        window.scrollTo({
          top: this.offsetTop - 20,
          behavior: 'smooth'
        });
      };

      if (document.startViewTransition) {
        document.startViewTransition(switchView);
      } else {
        switchView();
      }
    }

    async submitLead() {
      const selectedPortions = (this.calcData?.recipes || [])
        .filter(r => this.selectedRecipes.has(r.recipeName))
        .map(r => r.portionGrams);
      const avgPortion = selectedPortions.length
        ? selectedPortions.reduce((a, b) => a + b, 0) / selectedPortions.length
        : 0;

      const payload = {
        ownerName:            this.querySelector('#userName').value,
        email:                this.querySelector('#userEmail').value,
        phone:                this.querySelector('#userPhone').value,
        zip:                  this.querySelector('#userZip').value,
        dogName:              this.querySelector('#dogName').value,
        dailyCalories:        this.calcData?.dailyCalories ?? 0,
        portionGrams:         avgPortion,
        specialRequirements:  this.querySelector('#userMessage').value,
        source:               'ChefPaws Calculator',
      };

      await fetch(`${this.apiUrl}/api/lead`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      this.querySelector('#lead-form-container').classList.add('hidden');
      this.querySelector('#success-message').classList.remove('hidden');
    }
  }
  customElements.define('nutrition-calculator', NutritionCalculator);
</script>