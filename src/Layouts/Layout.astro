---
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <!-- Anti-FOUC: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', stored ?? preferred);
      })();
    </script>

    <ClientRouter />
    <meta charset="UTF-8" />
    <title>{title} | ChefPaws</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <Nav />
    <main transition:animate="fade">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* ── Light mode tokens ─────────────────────────────────────────── */
  :root {
    --brand-dark:    #121212;
    --brand-accent:  #ff6b6b;
    --brand-soft:    #f8f8f6;
    --brand-surface: #ffffff;
    --text-muted:    #8e8e93;
    --border-light:  #eeeeee;
    --shadow-soft:   0 20px 40px rgba(0,0,0,0.04);

    /* Semantic tokens used for dark-mode overrides */
    --bg-page:       #f8f8f6;
    --bg-section:    #ffffff;
    --bg-surface:    #fafaf9;
    --text-primary:  #111111;
    --text-secondary:#888888;
    --input-bg:      #ffffff;
    --input-border:  #e5e5e5;

  }

  /* ── Dark mode token overrides ─────────────────────────────────── */
  [data-theme="dark"] {
    --brand-dark:    #ebebeb;
    --brand-soft:    #0f0f0f;
    --brand-surface: #191919;
    --text-muted:    #888888;
    --border-light:  #282828;
    --shadow-soft:   0 20px 40px rgba(0,0,0,0.5);

    --bg-page:       #0f0f0f;
    --bg-section:    #111111;
    --bg-surface:    #1a1a1a;
    --text-primary:  #ebebeb;
    --text-secondary:#888888;
    --input-bg:      #1e1e1e;
    --input-border:  #333333;

    color-scheme: dark;
  }

  /* ── Reset ─────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
    margin: 0;
    padding: 0;
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  html {
    background-color: var(--bg-page);
    transition: background-color 0.25s ease;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background-color: var(--bg-page);
    color: var(--text-primary);
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    transition: background-color 0.25s ease, color 0.25s ease;
  }

  main {
    flex: 1;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem clamp(0rem, 5vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    background-color: var(--bg-page);
  }

  img, video, canvas, svg { max-width: 100%; height: auto; }

  /* ── Global dark overrides for component hardcoded colors ──────── */

  /* Section backgrounds */
  [data-theme="dark"] section {
    background-color: var(--bg-section) !important;
  }

  /* Headings */
  [data-theme="dark"] h1,
  [data-theme="dark"] h2,
  [data-theme="dark"] h3 {
    color: var(--text-primary) !important;
  }

  /* Body text & muted text */
  [data-theme="dark"] p {
    color: inherit;
  }

  /* Axis / timeline lines */
  [data-theme="dark"] .step-description,
  [data-theme="dark"] .section-subtitle {
    color: var(--text-secondary) !important;
  }

  /* Form card */
  [data-theme="dark"] .contact-form {
    background: var(--bg-surface) !important;
    border-color: var(--input-border) !important;
  }

  /* Form inputs */
  [data-theme="dark"] input,
  [data-theme="dark"] textarea {
    background: var(--input-bg) !important;
    border-color: var(--input-border) !important;
    color: var(--text-primary) !important;
  }

  [data-theme="dark"] input::placeholder,
  [data-theme="dark"] textarea::placeholder {
    color: #555 !important;
  }

  [data-theme="dark"] label {
    color: #ccc !important;
  }

  /* Nav */
  [data-theme="dark"] .navbar {
    background: rgba(10, 10, 10, 0.85) !important;
    border-bottom-color: rgba(255, 255, 255, 0.06) !important;
  }

  [data-theme="dark"] .mobile-menu {
    background: #111 !important;
  }

  [data-theme="dark"] .mobile-menu a {
    color: #ebebeb !important;
  }

  /* CTA card (FinalCTA.svelte uses hardcoded white) */
  [data-theme="dark"] .cta-light-impact {
    background: var(--bg-section) !important;
  }

  [data-theme="dark"] .luxury-card {
    background: var(--bg-surface) !important;
    border-color: var(--input-border) !important;
  }

  /* ProcessTimeline step rail line */
  [data-theme="dark"] .step-rail::after {
    background: linear-gradient(to bottom, #333 0%, transparent 100%) !important;
  }

  /* ── Comparison Table ── */
  [data-theme="dark"] .comparison-section {
    background-color: #0f0f0f !important;
  }
  [data-theme="dark"] .table-container {
    background: #141414 !important;
    border-color: #2a2a2a !important;
    box-shadow: 0 40px 100px rgba(0,0,0,0.4) !important;
  }
  [data-theme="dark"] .table-container th {
    border-bottom-color: #2a2a2a !important;
  }
  [data-theme="dark"] .table-container td {
    border-bottom-color: #1e1e1e !important;
  }
  [data-theme="dark"] .feature-head {
    color: #555 !important;
  }
  [data-theme="dark"] .competitor-head {
    background: #1a1a1a !important;
    color: #555 !important;
  }
  [data-theme="dark"] .feature-label {
    color: #ebebeb !important;
  }
  [data-theme="dark"] .chefpaws-cell {
    background: rgba(255, 77, 77, 0.04) !important;
    color: #ebebeb !important;
    border-left-color: #2a2a2a !important;
  }
  [data-theme="dark"] .kibble-cell {
    background: #1a1a1a !important;
    color: #666 !important;
  }
  [data-theme="dark"] .kibble-cell .status-icon {
    color: #444 !important;
  }
  /* Mobile stacked rows */
  [data-theme="dark"] .comparison-section tr {
    border-bottom-color: #2a2a2a !important;
  }
  [data-theme="dark"] .comparison-section .feature-label {
    background: #1a1a1a !important;
  }
  [data-theme="dark"] .comparison-section .chefpaws-cell {
    color: #ebebeb !important;
  }

  /* Nav CTA pill — --brand-dark inverts to light in dark mode, making white
     text invisible. Force a light pill with dark text instead. */
  [data-theme="dark"] .cta-pill {
    background: #ebebeb !important;
    color: #111 !important;
  }
  [data-theme="dark"] .cta-pill:hover {
    background: var(--brand-accent) !important;
    color: #fff !important;
  }

  /* Footer */
  [data-theme="dark"] .footer {
    background: #0f0f0f !important;
    border-top-color: #1e1e1e !important;
    color: var(--text-primary) !important;
  }
  [data-theme="dark"] .cities {
    color: #aaa !important;
  }
  [data-theme="dark"] .footer-link {
    color: #666 !important;
  }
  [data-theme="dark"] .footer-link:hover {
    color: var(--brand-accent) !important;
  }
  [data-theme="dark"] .copyright {
    color: #555 !important;
  }
</style>
