---
import Layout from '../Layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturesGrid from '../components/Features.astro';
import TrustBar from '../components/TrustBar.svelte'; 
import VisualTeardown from '../components/VisualTeardown.svelte';
import ComparisonTable from '../components/ComparisonTable.svelte';
import FinalCTA from '../components/FinalCTA.svelte';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import ContactForm from '../components/ContactForm.svelte';
import type { HomepageResponse, Section } from '../types/drupal';

const { slug = "/" } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

const response = await fetch(`${API_URL}/page?slug=${slug}`);
if (!response.ok) return Astro.redirect('/404');

const data: HomepageResponse = await response.json();

/**
 * CLEAN CONTENT MAPPING
 * We pass raw URLs to Svelte components to allow Cloudflare to handle 
 * the optimization at the edge. This prevents the "Double-Optimization" 404s.
 */
const sections = data.sections || [];
---

<Layout title={data.title}>
  {sections.length > 0 ? (
    sections.map((section: Section) => {
      
      // Svelte: Visual Teardown
      if (section.type === 'paragraph--visual_teardown') {
        return (
          <div class="section-wrapper bowl-wrapper">
            <VisualTeardown {...(section.content as any)} client:visible />
          </div>
        );
      }

      // Svelte: Trust Bar
      if (section.type === 'paragraph--trust_bar') {
        return (
          <div class="section-wrapper trust-wrapper">
            <TrustBar {...(section.content as any)} client:visible />
          </div>
        );
      }

      // Svelte: Comparison Table
      if (section.type === 'paragraph--comparison_table') {
        return (
          <div class="section-wrapper table-wrapper">
            <ComparisonTable {...(section.content as any)} client:visible />
          </div>
        );
      }

      // Svelte: Final CTA
      if (section.type === 'paragraph--cta' || section.type === 'paragraph--final_cta') {
        return (
          <div class="section-wrapper cta-wrapper">
            <FinalCTA {...(section.content as any)} client:visible />
          </div>
        );
      }

      // Svelte: Contact Form
      if (section.type === 'paragraph--contact_form') {
        return <ContactForm {...(section.content as any)} client:load />;
      }

      // Astro: Process Timeline
      if (section.type === 'paragraph--process_steps') {
        return <ProcessTimeline steps={(section.content as any).field_process_steps ?? []} />;
      }

      // Static Astro Components
      if (section.type === 'paragraph--hero') {
        return <Hero {...(section.content as any)} />;
      }

      if (section.type === 'paragraph--features_grid') {
        return <FeaturesGrid {...(section.content as any)} />;
      }

      return null;
    })
  ) : (
    <div class="empty-state">
      <h1>No content found</h1>
      <p>Check the slug and Drupal status.</p>
    </div>
  )}
</Layout>

<style>
  /* STOPS THE "JUMPING" 
     We reserve vertical space for the Svelte components so the page 
     doesn't "collapse" while the JavaScript is loading.
  */
  .section-wrapper {
    width: 100%;
    /* Improves scroll performance by not rendering until near viewport */
    content-visibility: auto; 
    contain-intrinsic-size: 1px 500px;
  }

  .bowl-wrapper { min-height: 800px; }
  .trust-wrapper { min-height: 140px; }
  .table-wrapper { min-height: 600px; }
  .cta-wrapper   { min-height: 400px; }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }
</style>