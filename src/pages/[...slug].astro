---
import { getImage } from "astro:assets";
import Layout from '../Layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturesGrid from '../components/Features.astro';
import TrustBar from '../components/TrustBar.svelte'; 
import VisualTeardown from '../components/VisualTeardown.svelte';
import ComparisonTable from '../components/ComparisonTable.svelte';
import FinalCTA from '../components/FinalCTA.svelte';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import ContactForm from '../components/ContactForm.svelte';
import type { HomepageResponse, Section } from '../types/drupal';

const { slug = "/" } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

const response = await fetch(`${API_URL}/page?slug=${slug}`);
if (!response.ok) return Astro.redirect('/404');

const data: HomepageResponse = await response.json();

/**
 * RESTORED IMAGE OPTIMIZATION
 * We process all R2/DDEV images through Astro's Sharp engine.
 * This ensures Svelte receives a local, optimized /_astro/ URL.
 */
const optimizedSections = await Promise.all((data.sections || []).map(async (section: Section) => {
  
  // 1. Visual Teardown "Bowl"
  if (section.type === 'paragraph--visual_teardown' && section.content.field_teardown_image) {
    try {
      const optimized = await getImage({
        src: section.content.field_teardown_image,
        width: 1000,
        inferSize: true,
        quality: 75,
        format: 'webp'
      });
      section.content.field_teardown_image = optimized.src;
    } catch (e) {
      console.error("Teardown optimization failed:", e);
    }
  }

  // 2. Trust Bar Icons
  if (section.type === 'paragraph--trust_bar' && section.content.field_trust_items) {
    section.content.field_trust_items = await Promise.all(
      section.content.field_trust_items.map(async (item: any) => {
        if (!item.field_icon) return item;
        try {
          const optimizedIcon = await getImage({
            src: item.field_icon,
            width: 160,
            height: 160,
            quality: 80,
            format: 'webp'
          });
          return { ...item, field_icon: optimizedIcon.src };
        } catch (e) {
          return item;
        }
      })
    );
  }

  // 3. Features Grid
  if (section.type === 'paragraph--features_grid' && section.content.field_feature_items) {
    section.content.field_feature_items = await Promise.all(
      section.content.field_feature_items.map(async (item: any) => {
        if (!item.field_media) return item;
        try {
          const optimized = await getImage({
            src: item.field_media,
            width: 600,
            inferSize: true,
            quality: 80,
            format: 'webp'
          });
          return { ...item, field_media: optimized.src };
        } catch (e) {
          return item;
        }
      })
    );
  }

  return section;
}));
---

<Layout title={data.title}>
  {optimizedSections.length > 0 ? (
    optimizedSections.map((section: Section) => {
      
      if (section.type === 'paragraph--visual_teardown') {
        return (
          <div class="section-wrapper bowl-wrapper">
            <VisualTeardown {...(section.content as any)} client:visible />
          </div>
        );
      }

      if (section.type === 'paragraph--trust_bar') {
        return (
          <div class="section-wrapper trust-wrapper">
            <TrustBar {...(section.content as any)} client:visible />
          </div>
        );
      }

      if (section.type === 'paragraph--comparison_table') {
        return (
          <div class="section-wrapper table-wrapper">
            <ComparisonTable {...(section.content as any)} client:visible />
          </div>
        );
      }

      if (section.type === 'paragraph--cta' || section.type === 'paragraph--final_cta') {
        return (
          <div class="section-wrapper cta-wrapper">
            <FinalCTA {...(section.content as any)} client:visible />
          </div>
        );
      }

      if (section.type === 'paragraph--process_steps') {
        return <ProcessTimeline steps={(section.content as any).field_process_steps ?? []} />;
      }

      if (section.type === 'paragraph--contact_form') {
        return <ContactForm {...(section.content as any)} client:load />;
      }

      const COMPONENTS = {
        'paragraph--hero': Hero,
        'paragraph--features_grid': FeaturesGrid,
      } as const;

      const StaticComponent = COMPONENTS[section.type as keyof typeof COMPONENTS];
      return StaticComponent ? <StaticComponent {...(section.content as any)} /> : null;
    })
  ) : (
    <div class="empty-state">
      <h1>No content found</h1>
    </div>
  )}
</Layout>

<style>
  .section-wrapper {
    width: 100%;
    content-visibility: auto; 
    contain-intrinsic-size: 1px 500px;
  }
  .bowl-wrapper { min-height: 800px; }
  .trust-wrapper { min-height: 140px; }
  .table-wrapper { min-height: 600px; }
  .cta-wrapper   { min-height: 400px; }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }
</style>