
---
import Layout from '../Layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturesGrid from '../components/Features.astro';
import TrustBar from '../components/TrustBar.svelte'; 
import VisualTeardown from '../components/VisualTeardown.svelte';
import ComparisonTable from '../components/ComparisonTable.svelte';
import FinalCTA from '../components/FinalCTA.svelte';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import ContactForm from '../components/ContactForm.svelte';
import type { HomepageResponse, Section } from '../types/drupal';

// 1. Capture the slug. [...slug] captures everything after the domain.
const { slug = "/" } = Astro.params;

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

// 2. Log for debugging (Check your terminal where Astro is running!)
console.log(`🚀 Fetching Page: ${slug} from ${API_URL}/page?slug=${slug}`);

const response = await fetch(`${API_URL}/page?slug=${slug}`);

if (!response.ok) {
  console.error(`❌ API Error: ${response.status}`);
  return Astro.redirect('/404');
}

const data: HomepageResponse = await response.json();

// 3. Log the sections to see if Go is actually sending data
console.log(`📦 Sections found: ${data.sections?.length || 0}`);

const COMPONENTS = {
  'paragraph--hero': Hero,
  'paragraph--features_grid': FeaturesGrid,
  'paragraph--trust_bar': TrustBar,
  'paragraph--visual_teardown': VisualTeardown, 
  'paragraph--comparison_table': ComparisonTable,
  'paragraph--cta': FinalCTA,
} as const;

type ComponentKey = keyof typeof COMPONENTS;
---

<Layout title={data.title}>
  {data.sections && data.sections.length > 0 ? (
    data.sections.map((section: Section) => {
      
      // Svelte Components (Hydrated)
      if (section.type === 'paragraph--visual_teardown') {
        return <VisualTeardown {...(section.content as any)} client:visible />;
      }
      if (section.type === 'paragraph--trust_bar') {
        return <TrustBar {...(section.content as any)} client:visible />;
      }
      if (section.type === 'paragraph--cta' || section.type === 'paragraph--final_cta') {
        return <FinalCTA {...(section.content as any)} client:visible />;
      }
      if (section.type === 'paragraph--comparison_table') {
        return <ComparisonTable {...(section.content as any)} client:visible />;
      }

      // ProcessTimeline — explicit mapping because Drupal field name differs from prop name
      if (section.type === 'paragraph--process_steps') {
        return <ProcessTimeline steps={(section.content as any).field_process_steps ?? []} />;
      }
      if (section.type === 'paragraph--contact_form') {
        return <ContactForm {...(section.content as any)} client:load />;
      }

      // Static Astro Components
      const StaticComponent = COMPONENTS[section.type as ComponentKey];
      return StaticComponent ? <StaticComponent {...(section.content as any)} /> : null;
    })
  ) : (
    /* 4. Fallback UI if data.sections is empty */
    <div class="empty-state">
      <h1>No content found for "{slug}"</h1>
      <p>Check if the page is published in Drupal and that the Paragraphs are added.</p>
    </div>
  )}
</Layout>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    text-align: center;
    font-family: sans-serif;
  }
</style>